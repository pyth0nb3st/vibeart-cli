{
  "name": "vibeart-cli",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "homepage": "https://vibeart.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyth0nb3st/vibeart-cli.git"
  },
  "bugs": {
    "url": "https://github.com/pyth0nb3st/vibeart-cli/issues"
  },
  "files": [
    "dist",
    "README.md",
    "README.agent.md",
    ".env.example"
  ],
  "bin": {
    "vibeart": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --sourcemap --clean --out-dir dist",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "smoke:release": "bash scripts/smoke-release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "incur": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "execa": "^9.5.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  }
}
